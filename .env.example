ENVIRONMENT=dev
FASTAPI_TITLE=FBA App
FASTAPI_API_V1_PATH=/api/v1
DATETIME_TIMEZONE=Asia/Shanghai

# HTTP diagnostics
MIDDLEWARE_REQUEST_ID=true
MIDDLEWARE_RECOVER=true
MIDDLEWARE_RECOVER_STACK_TRACE=true
MIDDLEWARE_ACCESS_LOG=true
MIDDLEWARE_ACCESS_LOG_SKIP_PATHS=/healthz,/readyz,/metrics
MIDDLEWARE_ERROR_LOG=true
ERROR_RESPONSE_INCLUDE_DETAIL=true
LOG_STD_LEVEL=INFO
LOG_ACCESS_FILENAME=.cache/logs/fba_access.log
LOG_ERROR_FILENAME=.cache/logs/fba_error.log

# CORS
MIDDLEWARE_CORS=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost:5173
CORS_EXPOSE_HEADERS=X-Request-ID

# IP location parsing
IP_LOCATION_PARSE=none
# IP_LOCATION_XDB_PATH=.cache/ip2region/ip2region_v4.xdb
# IP_LOCATION_V6_XDB_PATH=.cache/ip2region/ip2region_v6.xdb
IP_LOCATION_CACHE_POLICY=vectorIndex
IP_LOCATION_SEARCHERS=20

# Realtime
REALTIME_DISABLED=false

# Database
DATABASE_DRIVER=
DATABASE_DSN=
DATABASE_AUTO_MIGRATE=false

# Redis
REDIS_MODE=
REDIS_ADDR=127.0.0.1:6379
REDIS_DB=0
